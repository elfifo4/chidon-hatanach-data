      "question_units": [
        {
          "unit_id": "q01",
          "display_number": "1",
          "narrative_context": null,
          "prompt": "ההיסטוריה האנושית מלמדת כי בעתות רעב נודדים בני האדם ותרים אחר מקום שבו יוכלו להשיג מזון. לאיזה מבין המקומות הבאים לא נדדו כדי להשיג מזון?",
