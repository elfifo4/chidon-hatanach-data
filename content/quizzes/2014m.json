        {
          "unit_id": "q02",
          "display_number": "2",
          "narrative_context": "קָטנְֹ תִּי מִּכלֹ הַחֲסָדִּים וּמִּכָל- הָאֱמֶת אֲשֶר עָשִּי תָאֶת- עַבְדֶךָ כִּי בְמַקְלִּי עָבַרְתִּי אֶת- הַיַ רְדֵּן הַזֶה וְעַתָה הָייִּ תִּי לִּשְניֵּ מַחֲנוֹת. הַצִּי לֵּניִּ נאָ...",
          "prompt": ". מי אמר את הדברים?",
          "question_type": "speaker_id",
          "answer_style": "single_correct",
          "options": [
            {
