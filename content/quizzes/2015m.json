              "key": "א",
              "text": "ברכה"
            },
            {
              "key": "ב",
              "text": "בכורה"
            },
            {
              "key": "ג",
              "text": "מערה"
            },
            {
              "key": "ד",
              "text": "נער"
            }
          ],
          "correct_option": null,
          "subquestions": null,
          "primary_sources": [],
