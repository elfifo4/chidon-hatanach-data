        {
          "unit_id": "q03",
          "display_number": "3",
          "narrative_context": "נַ ֲע ֶשה וְנִּ ְׁש ַמע\"",
          "prompt": "באיזה אירוע אמרו בני העם?",
          "question_type": "multiple_choice",
          "answer_style": "single_correct",
          "options": [
            {
              "key": "א",
              "text": "בהכרזה על יציאת מצרים"
            },
            {
              "key": "ב",
              "text": "בעת הציווי לחצות את ים סּוף"
            },
            {
              "key": "ג",
              "text": "בעת כריתת הברית בהר סיני"
            },
            {
              "key": "ד",
              "text": "בעת כריתת הברית בגלגל 5. \" ְסדֹום וַ ֲעמֹו ָרה\" היו שתי ערים מקראיות מפורסמות שתושביהן חטאו מאוד. עד היום משתמשים בשמותיהן כדי לבטא אי סדר ומצב שאינו תקין. מה היה סופן של הערים האלה?"
            },
            {
              "key": "א",
              "text": "הרס וחורבן"
            },
            {
              "key": "ב",
              "text": "תושביהן חזרו בתשובה"
            },
            {
              "key": "ג",
              "text": "תושביהן הוגלו"
            },
            {
              "key": "ד",
              "text": "תושביהן נפלו בקרב"
            }
          ],
