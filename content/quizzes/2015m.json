      "question_units": [
        {
          "unit_id": "q01",
          "display_number": "1",
          "narrative_context": "מְעַט צֳרִּי וּמְעַט דְבַשׁ נכְאֹת ולָֹט בָטְניִּם וּשְׁקֵדִּים.",
          "prompt": "הצירוף \" זִּמְרַת הָאָ רֶץ\" הוא כינוי למוצרים החקלאיים המאפיינים את ארץ ישראל: מי האיש ש מִּנחה כזאת הובאה אליו?",
          "question_type": "multiple_choice",
          "answer_style": "single_correct",
          "options": [
