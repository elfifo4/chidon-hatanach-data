        {
          "unit_id": "q03",
          "display_number": "3",
          "narrative_context": "חֲלִּי לָהּ לִּי מֵעֲשׂוֹת זאֹת.",
          "prompt": "לאיזו הצעה סירב האיש שאמר זאת?",
          "question_type": "multiple_choice",
          "answer_style": "single_correct",
          "options": [
            {
              "key": "א",
              "text": "להפוך קבוצת אנשים לעבדים"
            },
            {
              "key": "ב",
              "text": "לשחרר עם של עבדים"
            },
            {
              "key": "ג",
              "text": "למכור את אחיו"
            },
            {
              "key": "ד",
              "text": "לרמות את אחיו 5. מה הייתה תגובתו של עגלון כאשר אמר אהוד: \" דְבַר אֱלֹ הִּים לִּי אֵלֶיךָ\"?"
            },
            {
              "key": "א",
              "text": "הוא נפל על פניו"
            },
            {
              "key": "ב",
              "text": "הוא קרע את בגדיו"
            },
            {
              "key": "ג",
              "text": "הוא קם מעל הכיסא"
            },
            {
              "key": "ד",
              "text": "הוא נעל את הדלת"
            }
          ],
          "correct_option": null,
          "subquestions": null,
          "primary_sources": [],
