            },
            {
              "key": "ב",
              "text": "נתן"
            },
            {
              "key": "ג",
              "text": "אליהו"
            },
            {
              "key": "ד",
              "text": "גד חלק שני : נא ענו על השאלה המצורפת לכל קטע פסוק 16 . מי אמר : \" וְשִׁכַּנְ תִּי אֶתְכֶם בַּמָּקוֹם הַזֶּה בָּאָרֶץ אֲשֶׁר נָתַ תִּי לַאֲבוֹתֵיכֶם לְמִן עוֹלָם וְעַד עוֹלָם:\"? תשובה : ____________________________________________ 17 . מי אמר:\" וַאֲנִי בַּה׳ אֲצַפֶּה אוֹ חִילָה לֵאלֹהֵי יִשְׁעִי יִשְׁמָעֵנִי אֱלֹהָי:\"? תשובה : ____________________________________________ 18 . מי אמר :\" וַתַּגְדִּילוּ עָלַי בְּפִיכֶם וְהַעְתַּרְתֶּם עָלַי דִּבְרֵיכֶם אֲנִי שָׁמָעְ תִּי: \"? תשובה : ____________________________________________ 19. איזה שער , משערי חומת ירושלים, הֶחֱזִיקוּ יוֹיָדָע בֶּן פָּסֵחַ וּמְשֻׁלָּם בֶּן בְּסוֹדְיָה ? תשובה : ____________________________________________ 20 . מי אמר : \"וְעָמַד וְרָעָה בְּעזֹ ה׳ בִּגְאוֹן שֵׁם ה׳ אֱלֹהָיו וְיָ שָׁבוּ כִּי עַתָּה יִגְדַּל עַד אַפְסֵי אָרֶץ\"? תשובה : ____________________________________________ 21 . מי אמר:\" הֵן לֹא קָצְרָה יַד ה׳ מֵהוֹ שִׁיעַ וְלֹא כָבְדָה אָזְנוֹ מִשְּׁמוֹעַ:\"? תשובה : ____________________________________________ 22 . מי החזיק את שַׁעַר הָאַ שְׁפּוֹת בימי נחמיה ? תשובה : ____________________________________________ . מי אמר:\" כִּי קָרוֹב יוֹם ה׳ עַל כָּל הַגּוֹיִם כַּאֲ שֶׁר עָשִׂיתָ יֵעָ שֶׂה לָּךְ גְּמֻלְךָ יָשׁוּב בְּראֹ שֶׁךָ:\"? תשובה : ____________________________________________ 24 . מי אמר:\"וְ הִגְלֵי תִי אֶתְכֶם מֵהָלְאָה לְדַמָּ שֶׂק אָמַר ה׳ אֱלֹהֵי צְבָאוֹת שְׁמוֹ:\"? תשובה : ____________________________________________ 25 . למי נאמר :\" בּאֹ הִסָּגֵר בְּתוֹךְ בֵּיתֶךָ:\"? תשובה : ____________________________________________ 26 . מי אמר:\" הֲיַעֲזבֹ מִצּוּר שָׂדַי שֶׁלֶג לְבָנוֹן אִם יִנָּ תְשׁוּ מַיִם זָרִים קָרִים נוֹזְלִים: \"? תשובה : ____________________________________________ 27 . מי אמר:\" תָּרםֹ יָדְךָ עַל צָרֶיךָ וְכָל איְֹבֶיךָ יִכָּרֵתוּ:\"? תשובה : ____________________________________________ 28 . מי אמר:\" וְלֹא אַסְתִּיר עוֹד פָּנַי מֵהֶם אֲשֶׁר שָׁפַכְ תִּי אֶת רוּ חִי עַל בֵּית יִשְׂרָאֵל נְאֻם ה׳ אלוקים \"? תשובה : ____________________________________________ 29 . מי אמר:\"וַאֲכַלְתֶּם אָכוֹל וְשָׂבוֹעַ וְהִלַּלְתֶּם אֶת שֵׁם ה׳ אֱלֹהֵיכֶם אֲשֶׁר עָשָׂה עִמָּכֶם לְהַפְלִיא וְלֹא יֵבשֹׁוּ עַמִּי לְעוֹלָם:\"? תשובה : ____________________________________________ 30 . מי אמר:\"וְעַד זִקְנָה אֲנִי הוּא וְעַד שֵׂיבָה אֲנִי אֶסְבּלֹ אֲנִי עָשִׂי תִי וַאֲנִי אֶשָּׂא וַאֲנִי אֶסְבּלֹ וַאֲמַלֵּט\"? תשובה : ____________________________________________ חלק שלישי: השלם את הפסוקים הבאים נא רשום את המילים החסרות בלשון הכתוב 32-31 . מְפַנֵּק מִנּעַֹר ______________וְאַחֲרִיתוֹ יִהְיֶה ______________: 34-33. הַיְרֻצוּן ______________ סוּ סִים אִם יַחֲרוֹשׁ ______________ כִּי הֲפַכְתֶּם לְראֹשׁ מִשְׁפָּט וּפְרִי צְדָקָה לְלַעֲנָה: 36-35. קרֵֹא מִמִּזְרָח ______________מֵאֶרֶץ מֶרְחָק אִישׁ ______________ אַף דִּבַּרְ תִּי אַף אֲבִיאֶנָּה יָצַרְ תִּי אַף אֶעֱ שֶׂנָּה: 38-37. יְרָא אֶת ה׳ בְּנִי ______________ עִם שׁוֹנִים אַל ______________: 40-39. כְּקוֹל ______________עַל רָא שֵׁי הֶהָרִים יְרַקֵּדוּן כְּקוֹל ______________אֵשׁ אכְֹלָה קָשׁ כְּעַם עָצוּם עֱרוּךְ מִלְחָמָה: 42-41. שֵׁבֶט ______________יִתֵּן חָכְמָה וְנַעַר ______________מֵבִישׁ אִמּוֹ: 44-43. וַהֲ קִמתִֹי לָהֶם ______________לְשֵׁם וְלֹא יִהְיוּ עוֹד אֲסֻפֵי ______________ בָּאָרֶץ וְלֹא יִשְׂאוּ עוֹד כְּלִמַּת הַגּוֹיִם: 46-45. עֵינֵי ה׳ נָצְרוּ ______________וַיְסַלֵּף דִּבְרֵי______________: 48-47. גַּם______________בַ שָּׁמַיִם יָדְעָה מוֹעֲדֶיהָ וְתרֹ וְסִיס ______________ שָׁמְרוּ אֶת עֵת בּאָֹנָה וְעַ מִּי לֹא יָדְעוּ אֵת מִשְׁפַּט ה׳: 50-49. שֶׁמֶן ______________ יְשַׂמַּח לֵב ______________ רֵעֵהוּ מֵעֲצַת נָפֶשׁ: בהצלחה"
            }
